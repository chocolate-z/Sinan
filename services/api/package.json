{
  "name": "@sinan/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "司南 api 网关(NestJS + Fastify):REST/SSE/SQLite 单一写者/凭据代理/任务编排",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "test": "tsc -p tsconfig.build.json && node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@sinan/shared-contracts": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^6.0.3"
  }
}
