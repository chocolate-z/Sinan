{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sinan",
  "version": "0.1.6",
  "identifier": "com.sinan.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:9521",
    "beforeDevCommand": "pnpm --filter @sinan/desktop dev",
    "beforeBuildCommand": "pnpm --filter @sinan/desktop build"
  },
  "app": {
    "windows": [
      {
        "title": "司南 Sinan",
        "width": 1280,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": ["sidecars/**/*"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false,
        "installerHooks": "installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://gh-proxy.com/https://github.com/chocolate-z/Sinan/releases/latest/download/latest-cn.json",
        "https://github.com/chocolate-z/Sinan/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUyMDg0QTI5RTM3MDAzNDYKUldSR0EzRGpLVW9JVXNGUElxUlc0LzlCcy9ueVhTUFlCSFNxRitBM1g0cDZCdkt3Z0VoUGdQYW8K"
    }
  }
}
