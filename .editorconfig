# 司南统一编辑器风格。与 .prettierrc 对齐(2 空格 / LF / UTF-8 / 末尾换行)。
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python(engine):PEP8 四空格
[*.py]
indent_size = 4

# Rust(外壳):rustfmt 四空格
[*.rs]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

# Markdown:保留行尾空格(硬换行语义),避免被裁剪
[*.md]
trim_trailing_whitespace = false

# 锁文件不手改
[pnpm-lock.yaml]
indent_size = unset
insert_final_newline = unset
