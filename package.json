{
  "name": "sinan",
  "version": "0.0.0",
  "private": true,
  "description": "司南 Sinan — 面向中国 A 股个人投资者的可分发本地量化桌面软件",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:contracts": "pnpm --filter @sinan/shared-contracts build",
    "test:contracts": "pnpm --filter @sinan/shared-contracts test",
    "test:api": "pnpm --filter @sinan/api test",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "0.25.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.1",
    "vue-eslint-parser": "^10.0.0"
  }
}
